// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== MASTER DATA TABLES ====================

model CourseLevel {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories CourseCategory[]
  Courses    Courses[]

  @@map("course_levels")
}

model CourseDurationType {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories CourseCategory[]

  @@map("course_duration_types")
}

model AwardCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  certificates CertificateTemplate[]

  @@map("award_categories")
}

// ==================== COURSE CATEGORY ====================

model CourseCategory {
  id                 String    @id @default(cuid())
  name               String
  code               String    @unique
  description        String?
  color              String    @default("#49205E")
  icon               String?
  categoryLogo       String?
  categoryBackground String?
  isDraft            Boolean   @default(false)
  isActive           Boolean   @default(true)
  synced             Boolean   @default(false)
  syncedAt           DateTime?
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  levelId        String?
  level          CourseLevel?        @relation(fields: [levelId], references: [id])
  durationTypeId String?
  durationType   CourseDurationType? @relation(fields: [durationTypeId], references: [id])

  certificateTemplate CertificateTemplate?
  Courses             Courses[]

  @@map("course_categories")
}

// ==================== CERTIFICATE TEMPLATE ====================

model CertificateTemplate {
  id                String   @id @default(cuid())
  certificateName   String
  passThreshold     Int      @default(75)
  includeRanking    Boolean  @default(true)
  includeScore      Boolean  @default(true)
  validityPeriod    String   @default("Lifetime")
  gradeA            Int      @default(90)
  gradeB            Int      @default(75)
  gradeC            Int      @default(60)
  borderStyle       String   @default("classic")
  backgroundColor   String   @default("#FFFFFF")
  primaryColor      String   @default("#49205E")
  accentColor       String   @default("#BC579E")
  logoUrl           String?
  backgroundPattern String?
  sealEnabled       Boolean  @default(true)
  qrPosition        String   @default("bottom-right")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  categoryId      String         @unique
  category        CourseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  awardCategoryId String?
  awardCategory   AwardCategory? @relation(fields: [awardCategoryId], references: [id])

  @@map("certificate_templates")
}

model ValidityPeriod {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("validity_periods") // IMPORTANT
}

model Courses {
  id          String   @id @default(uuid())
  title       String
  categoryId  String?
  levelId     String?
  duration    String?
  description String?
  createdBy   String?
  status      String   @default("Draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  Modules        Modules[]
  CourseLevel    CourseLevel?    @relation(fields: [levelId], references: [id])
  CourseCategory CourseCategory? @relation(fields: [categoryId], references: [id])

  @@map("courses")
}

model Modules {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  order       Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Courses @relation(fields: [courseId], references: [id], onDelete: Cascade)

  lessons Lessons[]

  @@unique([courseId, order])
  @@map("modules")
}

enum ContentType {
  Video
  PDF
  Document
  Assignment
  Link
}

model Lessons {
  id          String   @id @default(uuid())
  moduleId    String
  title       String
  contentType String // Video / PDF / Assignment / Link
  fileUrl     String? // optional (for link/video/pdf)
  order       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module Modules @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, order])
  @@map("lessons")
}

// ==================== AUTH SYSTEM ====================

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole
  isActive Boolean  @default(true)

  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  STUDENT
  PARENT
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("sessions")
}
